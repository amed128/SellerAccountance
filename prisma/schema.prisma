// SellerAccountance — Prisma schema
// PostgreSQL everywhere (Neon free tier works for both dev and prod).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  // Seller's country of establishment (ISO 3166-1 alpha-2) and VAT status.
  // Drives which country is "domestic" in the VAT engine and whether VAT
  // applies at all (franchise en base / small-business exemption).
  homeCountry  String    @default("FR")
  vatRegime    String    @default("STANDARD") // STANDARD | FRANCHISE
  // Has the user completed the first-launch configuration wizard? Gates
  // access to the rest of the app until home country / VAT regime are set
  // deliberately, rather than silently relying on the FR/STANDARD defaults.
  onboarded    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  reports      Report[]
  sessions     Session[]
}

// Opaque-token database session (cookie holds only the token).
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// One uploaded file = one Report
model Report {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  fileName     String
  reportType   String // VAT_TRANSACTIONS | SETTLEMENT | DATE_RANGE
  periodStart  DateTime?
  periodEnd    DateTime?
  currency     String        @default("EUR")
  rowCount     Int           @default(0)
  uploadedAt   DateTime      @default(now())
  transactions Transaction[]

  @@index([userId])
}

// Normalized transaction — every report type maps into this shape
model Transaction {
  id       String @id @default(cuid())
  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  date            DateTime?
  type            String // SALE | REFUND | FEE | FBA_FEE | OTHER | LIQUIDATION | SHIPMENT ...
  orderId         String?
  sku             String?
  description     String?
  quantity        Int       @default(0)
  marketplace     String?
  arrivalCountry  String? // ship-to country (VAT report)
  departCountry   String? // ship-from country (VAT report)
  buyerVatNumber  String? // present => B2B
  amountExclVat   Float     @default(0)
  vatRate         Float? // e.g. 0.20
  vatAmount       Float     @default(0)
  amountInclVat   Float     @default(0)
  fees            Float     @default(0) // selling fees (negative)
  fbaFees         Float     @default(0) // fulfillment fees (negative)
  otherFees       Float     @default(0)
  total           Float     @default(0) // net movement for this row
  currency        String    @default("EUR")

  @@index([reportId])
  @@index([type])
  @@index([arrivalCountry])
}
